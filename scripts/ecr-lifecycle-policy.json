{
  "rules": [
    {
      "rulePriority": 1,
      "description": "Remove untagged images after 14 days",
      "selection": {
        "tagStatus": "untagged",
        "countType": "sinceImagePushed",
        "countNumber": 14,
        "countUnit": "days"
      },
      "action": {
        "type": "expire"
      }
    },
    {
      "rulePriority": 2,
      "description": "Expire images older than 90 days",
      "selection": {
        "tagStatus": "any",
        "countType": "sinceImagePushed",
        "countNumber": 90,
        "countUnit": "days"
      },
      "action": {
        "type": "expire"
      }
    }
  ]
}
